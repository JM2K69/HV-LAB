<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HVLab.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HyperV Lab Manager"
    Width="1400"
    Height="900">
    <Grid Background="#F0F0F0" Padding="20">
        <StackPanel Spacing="15">
            <TextBlock Text="Hyper-V Lab Manager" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" />
            <Button Content="Rafraîchir Commutateurs" Click="RefreshSwitches_Click" Padding="12,8" />
            <Button Content="Rafraîchir Machines Virtuelles" Click="RefreshVMs_Click" Padding="12,8" />
            <TextBlock x:Name="StatusText" Text="Prêt..." FontSize="12" Foreground="#666" />
        </StackPanel>
    </Grid>
</Window>
