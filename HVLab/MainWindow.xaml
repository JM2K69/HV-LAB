<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HVLab.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HV-LAB Manager">

    <Grid>
        <!-- Custom TitleBar drag region (invisible, just defines the draggable area) -->
        <Grid x:Name="AppTitleBar"
              Height="40"
              VerticalAlignment="Top"
              HorizontalAlignment="Stretch"
              Canvas.ZIndex="1"
              IsHitTestVisible="True"/>

        <NavigationView
            x:Name="NavView"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
            CompactModeThresholdWidth="0"
            ExpandedModeThresholdWidth="0"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <!-- Pane header: app title inside pane -->
            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Spacing="10"
                            Margin="14,12,0,4">
                    <Border Width="32" Height="32" CornerRadius="6"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <FontIcon Glyph="&#xE7F8;" FontSize="16" Foreground="White"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="HV-LAB" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Manager" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="dashboard" Content="Tableau de bord">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="vms" Content="Machines Virtuelles">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F8;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="switches" Content="Commutateurs &amp; NAT">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA3;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="basevhdx" Content="Images de base VHDX">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="createvm" Content="Créer une VM">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE710;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="settings" Content="Paramètres">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" IsNavigationStackEnabled="False"/>
        </NavigationView>
    </Grid>
</Window>
