<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.VirtualSwitchesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HVLab.Models"
    Background="Transparent">

    <ScrollViewer>
        <Grid Padding="36,24,36,20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding [SW_Title], Source={StaticResource Loc}}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="{Binding [Btn_Refresh], Source={StaticResource Loc}}"/>
                </StackPanel>
            </Button>
        </Grid>

        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Pivot tabs -->
        <Pivot Grid.Row="2">

            <!-- ═══ Tab 1 : vSwitches ═══ -->
            <PivotItem Header="{Binding [SW_TabSwitches], Source={StaticResource Loc}}">
                <Grid RowSpacing="12" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Grid Grid.Row="0"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                          Padding="12,6" CornerRadius="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [SW_ColName], Source={StaticResource Loc}}"     FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding [SW_ColType], Source={StaticResource Loc}}"     FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{Binding [SW_ColAdapters], Source={StaticResource Loc}}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="{Binding [VM_ColActions], Source={StaticResource Loc}}"  FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Switch list -->
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.VirtualSwitches, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding"                    Value="12,0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="MinHeight"                  Value="42"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:VirtualSwitch">
                                <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind Name}"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind SwitchType}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind NetAdapterName}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="3" Tag="{x:Bind}" Click="RemoveSwitch_Click"
                                            Width="32" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Delete / Supprimer">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Create switch form -->
                    <Expander Grid.Row="2" Header="{Binding [SW_CreateTitle], Source={StaticResource Loc}}" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <StackPanel Spacing="10" Padding="0,8,0,4">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{Binding [SW_NameLabel], Source={StaticResource Loc}}" FontSize="12"/>
                                    <TextBox Text="{x:Bind ViewModel.NewSwitchName, Mode=TwoWay}"
                                             PlaceholderText="Ex. : NAT-Switch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding [SW_TypeLabel], Source={StaticResource Loc}}" FontSize="12"/>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.SwitchTypes}"
                                              SelectedItem="{x:Bind ViewModel.NewSwitchType, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4"
                                        Visibility="{x:Bind ViewModel.IsExternalSwitch, Mode=OneWay,
                                                      Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Physical network adapter" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.NetworkAdapters, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedNetAdapter, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="Select adapter…"/>
                            </StackPanel>

                            <Button Content="{Binding [SW_BtnCreate], Source={StaticResource Loc}}"
                                    Command="{x:Bind ViewModel.CreateSwitchCommand}"
                                    Style="{StaticResource AccentButtonStyle}"/>
                        </StackPanel>
                    </Expander>
                </Grid>
            </PivotItem>

            <!-- ═══ Tab 2 : NAT ═══ -->
            <PivotItem Header="{Binding [SW_TabNAT], Source={StaticResource Loc}}">
                <Grid RowSpacing="12" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Headers -->
                    <Grid Grid.Row="0"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                          Padding="12,6" CornerRadius="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [NAT_ColName], Source={StaticResource Loc}}"   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding [NAT_ColSubnet], Source={StaticResource Loc}}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{Binding [Lbl_Status], Source={StaticResource Loc}}"    FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="{Binding [VM_ColActions], Source={StaticResource Loc}}" FontWeight="SemiBold"/>
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.NatNetworks, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding"                    Value="12,0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="MinHeight"                  Value="42"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:NatNetwork">
                                <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind InternalIPInterfaceAddressPrefix}"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Status}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Tag="{x:Bind}" Click="RemoveNat_Click"
                                            Width="32" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Delete / Supprimer">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Create NAT form -->
                    <Expander Grid.Row="2" Header="{Binding [NAT_CreateTitle], Source={StaticResource Loc}}" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <StackPanel Spacing="10" Padding="0,8,0,4">
                            <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                                     Title="Prérequis / Prerequisites"
                                     Message="Un commutateur Internal doit exister. / An Internal switch must exist first."/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{Binding [NAT_NameLabel], Source={StaticResource Loc}}" FontSize="12"/>
                                    <TextBox Text="{x:Bind ViewModel.NewNatName, Mode=TwoWay}"
                                             PlaceholderText="Ex. : NAT-192.168.100"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Internal switch" FontSize="12"/>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.InternalSwitchNames, Mode=OneWay}"
                                              SelectedItem="{x:Bind ViewModel.SelectedNatSwitch, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="Select…"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Gateway IP" FontSize="12"/>
                                    <TextBox Text="{x:Bind ViewModel.NatGatewayIP, Mode=TwoWay}"
                                             PlaceholderText="192.168.100.1"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Prefix (/)" FontSize="12"/>
                                    <NumberBox Value="{x:Bind ViewModel.NatPrefixLength, Mode=TwoWay}"
                                               Minimum="8" Maximum="30" SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                            </Grid>
                            <Button Content="{Binding [NAT_BtnCreate], Source={StaticResource Loc}}"
                                    Command="{x:Bind ViewModel.CreateNatCommand}"
                                    Style="{StaticResource AccentButtonStyle}"/>
                        </StackPanel>
                    </Expander>
                </Grid>
            </PivotItem>

        </Pivot>
        </Grid>
    </ScrollViewer>
</Page>
