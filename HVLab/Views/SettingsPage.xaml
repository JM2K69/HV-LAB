<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="36,24,36,32" Spacing="4" MaxWidth="860">

            <!-- Page header -->
            <TextBlock Text="{Binding [SET_Title], Source={StaticResource Loc}}" FontSize="28" FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <!-- ══ Emplacements ══════════════════════════════════════════════ -->
            <TextBlock Text="{Binding [SET_SecFiles], Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>

            <ctk:SettingsCard Header="{Binding [SET_BaseImages], Source={StaticResource Loc}}"
                              Description="{Binding [SET_BaseImagesDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xEDA2;"/>
                </ctk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.BaseImagesFolder, Mode=TwoWay}"
                             PlaceholderText="C:\HV-LAB\BaseImages"
                             Width="320" FontFamily="Consolas" FontSize="12"/>
                    <Button Content="{Binding [Btn_Browse], Source={StaticResource Loc}}" Click="BrowseBaseImages_Click"/>
                </StackPanel>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="{Binding [SET_VMs], Source={StaticResource Loc}}"
                              Description="{Binding [SET_VMsDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7F8;"/>
                </ctk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.VmsFolder, Mode=TwoWay}"
                             PlaceholderText="C:\HV-LAB\VMs"
                             Width="320" FontFamily="Consolas" FontSize="12"/>
                    <Button Content="{Binding [Btn_Browse], Source={StaticResource Loc}}" Click="BrowseVms_Click"/>
                </StackPanel>
            </ctk:SettingsCard>

            <!-- ══ Système ══════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding [SET_SecSystem], Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,20,0,4"/>

            <ctk:SettingsCard Header="{Binding [SET_PSEngine], Source={StaticResource Loc}}"
                              Description="{Binding [SET_PSEngineDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE756;"/>
                </ctk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.PowerShellPath, Mode=TwoWay}"
                             PlaceholderText="C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe"
                             Width="320" FontFamily="Consolas" FontSize="11"/>
                    <Button Content="{Binding [Btn_Browse], Source={StaticResource Loc}}" Click="BrowsePowerShell_Click"/>
                </StackPanel>
            </ctk:SettingsCard>

            <!-- ══ Apparence ════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding [SET_SecAppearance], Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,20,0,4"/>

            <ctk:SettingsCard Header="{Binding [SET_Theme], Source={StaticResource Loc}}"
                              Description="{Binding [SET_ThemeDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE771;"/>
                </ctk:SettingsCard.HeaderIcon>
                <RadioButtons SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                              ItemsSource="{x:Bind ViewModel.Themes}">
                    <RadioButtons.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <RadioButton Content="{x:Bind}" Margin="0,0,16,0"/>
                        </DataTemplate>
                    </RadioButtons.ItemTemplate>
                </RadioButtons>
            </ctk:SettingsCard>

            <!-- Language card -->
            <ctk:SettingsCard Header="{Binding [SET_Language], Source={StaticResource Loc}}"
                              Description="{Binding [SET_LanguageDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xF2B7;"/>
                </ctk:SettingsCard.HeaderIcon>
                <ComboBox ItemsSource="{x:Bind ViewModel.Languages}"
                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                          MinWidth="120"/>
            </ctk:SettingsCard>

            <!-- ══ À propos ═════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding [SET_SecAbout], Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,20,0,4"/>

            <ctk:SettingsCard Header="{Binding [SET_AppName], Source={StaticResource Loc}}"
                              Description="{Binding [SET_AppDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;"/>
                </ctk:SettingsCard.HeaderIcon>
                <TextBlock Text="v1.0.0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="{Binding [SET_Persistence], Source={StaticResource Loc}}"
                              Description="{Binding [SET_PersistDesc], Source={StaticResource Loc}}">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE74E;"/>
                </ctk:SettingsCard.HeaderIcon>
            </ctk:SettingsCard>

            <!-- Bouton enregistrer -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,20,0,0">
                <Button Content="{Binding [Btn_Save], Source={StaticResource Loc}}"
                        Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
