<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="36,24,36,32" Spacing="4" MaxWidth="860">

            <!-- Page header -->
            <TextBlock Text="Paramètres" FontSize="28" FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <!-- ══ Emplacements ══════════════════════════════════════════════ -->
            <TextBlock Text="Emplacements des fichiers" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>

            <ctk:SettingsCard Header="Images de base VHDX"
                              Description="Dossier contenant les fichiers BASE_*.vhdx">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xEDA2;"/>
                </ctk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.BaseImagesFolder, Mode=TwoWay}"
                             PlaceholderText="C:\HV-LAB\BaseImages"
                             Width="320" FontFamily="Consolas" FontSize="12"/>
                    <Button Content="Parcourir…" Click="BrowseBaseImages_Click"/>
                </StackPanel>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="Machines virtuelles"
                              Description="Dossier où les disques différentiels et configs des VMs sont créés">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7F8;"/>
                </ctk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.VmsFolder, Mode=TwoWay}"
                             PlaceholderText="C:\HV-LAB\VMs"
                             Width="320" FontFamily="Consolas" FontSize="12"/>
                    <Button Content="Parcourir…" Click="BrowseVms_Click"/>
                </StackPanel>
            </ctk:SettingsCard>

            <!-- ══ Système ═══════════════════════════════════════════════════ -->
            <TextBlock Text="Système" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,20,0,4"/>

            <ctk:SettingsCard Header="Moteur PowerShell"
                              Description="Windows PowerShell 5.1 est requis pour le module Hyper-V.">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE756;"/>
                </ctk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.PowerShellPath, Mode=TwoWay}"
                             PlaceholderText="C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe"
                             Width="320" FontFamily="Consolas" FontSize="11"/>
                    <Button Content="Parcourir…" Click="BrowsePowerShell_Click"/>
                </StackPanel>
            </ctk:SettingsCard>

            <!-- ══ Apparence ══════════════════════════════════════════════════ -->
            <TextBlock Text="Apparence" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,20,0,4"/>

            <ctk:SettingsCard Header="Thème de l'application"
                              Description="Par défaut, l'application suit le thème configuré dans Windows.">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE771;"/>
                </ctk:SettingsCard.HeaderIcon>
                <RadioButtons SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                              ItemsSource="{x:Bind ViewModel.Themes}">
                    <RadioButtons.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <RadioButton Content="{x:Bind}" Margin="0,0,16,0"/>
                        </DataTemplate>
                    </RadioButtons.ItemTemplate>
                </RadioButtons>
            </ctk:SettingsCard>

            <!-- ══ À propos ═══════════════════════════════════════════════════ -->
            <TextBlock Text="À propos" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,20,0,4"/>

            <ctk:SettingsCard Header="HV-LAB Manager"
                              Description="Gestionnaire Hyper-V · VMs, vSwitch, NAT, VHDX · .NET 8 + WinUI 3">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;"/>
                </ctk:SettingsCard.HeaderIcon>
                <TextBlock Text="v1.0.0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="Persistance"
                              Description="Paramètres sauvegardés dans %LocalAppData%\HV-LAB\settings.json">
                <ctk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE74E;"/>
                </ctk:SettingsCard.HeaderIcon>
            </ctk:SettingsCard>

            <!-- Bouton enregistrer -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,20,0,0">
                <Button Content="Enregistrer les paramètres"
                        Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
