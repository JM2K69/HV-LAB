<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="28,20,28,28">
        <StackPanel Spacing="20">

            <!-- Header -->
            <Grid>
                <StackPanel>
                    <TextBlock Text="Tableau de bord Hyper-V" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                               FontSize="13" Foreground="{ThemeResource SystemBaseMediumColor}"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Actualiser"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Progress -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Hyper-V warning -->
            <InfoBar IsOpen="{x:Bind ViewModel.ShowHyperVWarning, Mode=OneWay}"
                     Severity="Warning"
                     Title="Hyper-V non disponible"
                     Message="Vérifiez que le rôle Hyper-V est installé et que l'application s'exécute en tant qu'administrateur."/>

            <!-- Summary cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0F7B0F" CornerRadius="8" Padding="18">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE768;" Foreground="White" FontSize="26"/>
                        <TextBlock Text="{x:Bind ViewModel.RunningVmCount, Mode=OneWay}"
                                   FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="VMs en cours" Foreground="White" Opacity="0.9"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#C42B1C" CornerRadius="8" Padding="18">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE71A;" Foreground="White" FontSize="26"/>
                        <TextBlock Text="{x:Bind ViewModel.StoppedVmCount, Mode=OneWay}"
                                   FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="VMs arrêtées" Foreground="White" Opacity="0.9"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#005A9E" CornerRadius="8" Padding="18">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xEDA3;" Foreground="White" FontSize="26"/>
                        <TextBlock Text="{x:Bind ViewModel.SwitchCount, Mode=OneWay}"
                                   FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Commutateurs" Foreground="White" Opacity="0.9"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#7A00CF" CornerRadius="8" Padding="18">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xEDA2;" Foreground="White" FontSize="26"/>
                        <TextBlock Text="{x:Bind ViewModel.BaseVhdxCount, Mode=OneWay}"
                                   FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Images de base" Foreground="White" Opacity="0.9"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Info cards -->
            <TextBlock Text="Démarrage rapide" FontSize="18" FontWeight="SemiBold"/>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Workflow recommandé" FontWeight="SemiBold" FontSize="14"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="1. Créer un commutateur interne" TextWrapping="Wrap"/>
                            <TextBlock Text="2. Configurer le NAT sur ce commutateur" TextWrapping="Wrap"/>
                            <TextBlock Text="3. Créer une image de base VHDX (WIM + réponse)" TextWrapping="Wrap"/>
                            <TextBlock Text="4. Créer des VMs avec disques différentiels" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Configuration système" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Dossier images de base :"
                                   Foreground="{ThemeResource SystemBaseMediumColor}"/>
                        <TextBlock Text="{x:Bind ViewModel.BaseVhdxFolder}"
                                   FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock Text="Élévation requise : Administrateur"
                                   Foreground="{ThemeResource SystemBaseMediumColor}"/>
                        <TextBlock Text="PowerShell requis : 5.1 ou supérieur"
                                   Foreground="{ThemeResource SystemBaseMediumColor}"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
