<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="36,20,36,32">
        <StackPanel Spacing="16">

            <!-- Header -->
            <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="{Binding [Dash_Title], Source={StaticResource Loc}}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Progress -->
            <ProgressBar IsIndeterminate="True" Margin="0,-8,0,0"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Hyper-V warning -->
            <InfoBar IsOpen="{x:Bind ViewModel.ShowHyperVWarning, Mode=OneWay}"
                     Severity="Warning"
                     Title="{Binding [Dash_HyperVWarn], Source={StaticResource Loc}}"
                     Message="{Binding [Dash_HyperVWarnMsg], Source={StaticResource Loc}}"
                     IsClosable="False"/>

            <!-- Action bar -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="{Binding [Btn_Refresh], Source={StaticResource Loc}}"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- ═══ Compteurs ════════════════════════════════════════════════ -->
            <TextBlock Text="{Binding [Dash_Overview], Source={StaticResource Loc}}" FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8,0,0"/>

            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- VMs en cours -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="8">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="#0F7B0F" HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE768;" Foreground="White" FontSize="16"/>
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.RunningVmCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding [Dash_RunningVMs], Source={StaticResource Loc}}" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- VMs arrêtées -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="8">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="#C42B1C" HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE71A;" Foreground="White" FontSize="16"/>
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.StoppedVmCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding [Dash_StoppedVMs], Source={StaticResource Loc}}" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Commutateurs -->
                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="8">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xEDA3;" Foreground="White" FontSize="16"/>
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.SwitchCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding [Dash_Switches], Source={StaticResource Loc}}" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Images de base -->
                <Border Grid.Column="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="8">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="#7A00CF" HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xEDA2;" Foreground="White" FontSize="16"/>
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.BaseVhdxCount, Mode=OneWay}"
                                   FontSize="32" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding [Dash_BaseImages], Source={StaticResource Loc}}" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Démarrage rapide ══════════════════════════════════════════ -->
            <TextBlock Text="{Binding [Dash_QuickStart], Source={StaticResource Loc}}" FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,12,0,0"/>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Workflow -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE762;" FontSize="18"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{Binding [Dash_Workflow], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="22" Height="22" CornerRadius="11"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="1" FontSize="11" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding [Dash_Step1], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="22" Height="22" CornerRadius="11"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="2" FontSize="11" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding [Dash_Step2], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="22" Height="22" CornerRadius="11"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="3" FontSize="11" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding [Dash_Step3], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="22" Height="22" CornerRadius="11"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="4" FontSize="11" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding [Dash_Step4], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Config système -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9F5;" FontSize="18"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{Binding [Dash_SysConfig], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding [Dash_BaseFolder], Source={StaticResource Loc}}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock Text="{x:Bind ViewModel.BaseVhdxFolder}"
                                       FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap"/>
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                       Margin="0,4,0,4"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D7;" FontSize="13"
                                          Foreground="#0F7B0F"/>
                                <TextBlock Text="{Binding [Dash_Elevation], Source={StaticResource Loc}}" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE756;" FontSize="13"
                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                <TextBlock Text="PowerShell 5.1" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
