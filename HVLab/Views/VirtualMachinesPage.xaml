<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.VirtualMachinesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HVLab.Models"
    Background="Transparent">

    <Grid Padding="36,24,36,20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Spacing="2">
                <TextBlock Text="Machines Virtuelles" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Actualiser"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Progress -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Column headers -->
        <Grid Grid.Row="2"
              Background="{ThemeResource SubtleFillColorSecondaryBrush}"
              Padding="16,8" CornerRadius="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Nom"         FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="1" Text="État"        FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="2" Text="Gén."        FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="3" Text="RAM"         FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="4" Text="CPU"         FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="5" Text="Commutateur" FontWeight="SemiBold" FontSize="12"/>
            <TextBlock Grid.Column="6" Text="Actions"     FontWeight="SemiBold" FontSize="12"/>
        </Grid>

        <!-- VM list -->
        <ListView Grid.Row="3"
                  ItemsSource="{x:Bind ViewModel.VirtualMachines, Mode=OneWay}"
                  SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding"                    Value="16,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="MinHeight"                  Value="48"/>
                    <Setter Property="CornerRadius"               Value="6"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:VirtualMachine">
                    <Grid ColumnSpacing="8" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nom -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7F8;" FontSize="14"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" FontWeight="Medium"
                                       ToolTipService.ToolTip="{x:Bind Name}"/>
                        </StackPanel>

                        <!-- État avec badge coloré -->
                        <Border Grid.Column="1" CornerRadius="12"
                                HorizontalAlignment="Left" Padding="10,3"
                                VerticalAlignment="Center"
                                Background="{x:Bind State, Converter={StaticResource StateToColorConverter}}">
                            <TextBlock Text="{x:Bind State}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>

                        <TextBlock Grid.Column="2" Text="{x:Bind GenDisplay}"
                                   VerticalAlignment="Center" FontSize="13"/>
                        <TextBlock Grid.Column="3" Text="{x:Bind MemoryDisplay}"
                                   VerticalAlignment="Center" FontSize="13"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind ProcessorCount}"
                                   VerticalAlignment="Center" FontSize="13"/>
                        <TextBlock Grid.Column="5" Text="{x:Bind SwitchName}"
                                   VerticalAlignment="Center" FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Actions -->
                        <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                            <Button Tag="{x:Bind}" Click="StartVm_Click"
                                    Width="32" Height="32" Padding="0"
                                    ToolTipService.ToolTip="Démarrer">
                                <FontIcon Glyph="&#xE768;" FontSize="12"/>
                            </Button>
                            <Button Tag="{x:Bind}" Click="StopVm_Click"
                                    Width="32" Height="32" Padding="0"
                                    ToolTipService.ToolTip="Arrêter">
                                <FontIcon Glyph="&#xE71A;" FontSize="12"/>
                            </Button>
                            <Button Tag="{x:Bind}" Click="RemoveVm_Click"
                                    Width="32" Height="32" Padding="0"
                                    ToolTipService.ToolTip="Supprimer">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <TextBlock Grid.Row="4"
                   Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Margin="0,4,0,0"/>
    </Grid>
</Page>
