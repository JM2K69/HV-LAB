<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.CreateVmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="36,24,36,28">
        <StackPanel Spacing="20" MaxWidth="760">

            <!-- Header -->
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding [CVM_Title], Source={StaticResource Loc}}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding [CVM_AnswerInfo], Source={StaticResource Loc}}"
                           FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Status InfoBar -->
            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Success"/>

            <!-- VM Identity -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding [CVM_Identity], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding [CVM_VmName], Source={StaticResource Loc}}" FontSize="12"/>
                        <TextBox Text="{x:Bind ViewModel.VmName, Mode=TwoWay}"
                                 PlaceholderText="Ex. : WIN11-LAB-01"/>
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding [CVM_BaseImage], Source={StaticResource Loc}}" FontSize="12"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.BaseVhdxList, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedBaseVhdx, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Sélectionnez une image…"
                                      FontFamily="Consolas" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="{Binding [CVM_Generation], Source={StaticResource Loc}}" FontSize="12"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.Generations}"
                                      SelectedItem="{x:Bind ViewModel.Generation, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Hardware -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding [CVM_Hardware], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding [CVM_RAM], Source={StaticResource Loc}}" FontSize="12"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.MemoryOptions}"
                                      SelectedItem="{x:Bind ViewModel.MemoryMB, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="{Binding [CVM_CPU], Source={StaticResource Loc}}" FontSize="12"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.CpuOptions}"
                                      SelectedItem="{x:Bind ViewModel.CpuCount, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Network -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding [CVM_Network], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding [CVM_Switch], Source={StaticResource Loc}}" FontSize="12"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.VirtualSwitches, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedSwitch, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="Sélectionnez un commutateur…"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Storage -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding [CVM_Storage], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>
                    <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                             Message="The differencing disk will be created in the VM folder. / Le disque différentiel sera créé dans le dossier VMs."/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding [CVM_VmFolder], Source={StaticResource Loc}}" FontSize="12"/>
                            <TextBox Text="{x:Bind ViewModel.VmFolder, Mode=TwoWay}"
                                     PlaceholderText="C:\HV-LAB\VMs"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                            <Button Content="{Binding [Btn_Browse], Source={StaticResource Loc}}" Click="BrowseVmFolder_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding [SET_BaseImages], Source={StaticResource Loc}}" FontSize="12"/>
                            <TextBox Text="{x:Bind ViewModel.BaseVhdxFolder, Mode=TwoWay}"
                                     PlaceholderText="C:\HV-LAB\BaseImages"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                            <Button Content="{Binding [CVM_BtnReload], Source={StaticResource Loc}}" Click="ReloadData_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Answer file -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8A5;" FontSize="16"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="{Binding [CVM_AnswerFile], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="15"/>
                    </StackPanel>

                    <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                             Message="{Binding [CVM_AnswerInfo], Source={StaticResource Loc}}"/>

                    <ToggleSwitch Header="{Binding [CVM_UseAnswer], Source={StaticResource Loc}}"
                                  IsOn="{x:Bind ViewModel.UseAnswerFile, Mode=TwoWay}"/>

                    <StackPanel Spacing="12"
                                Visibility="{x:Bind ViewModel.UseAnswerFile, Mode=OneWay,
                                              Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding [CVM_CompName], Source={StaticResource Loc}}" FontSize="12"/>
                                <TextBox Text="{x:Bind ViewModel.ComputerName, Mode=TwoWay}"
                                         MaxLength="15" PlaceholderText="LAB-VM"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding [CVM_AdminPwd], Source={StaticResource Loc}}" FontSize="12"/>
                                <PasswordBox Password="{x:Bind ViewModel.AdminPassword, Mode=TwoWay}"
                                             PlaceholderText="P@ssw0rd!"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding [CVM_Locale], Source={StaticResource Loc}}" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.Languages}"
                                          SelectedItem="{x:Bind ViewModel.UiLanguage, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding [CVM_Timezone], Source={StaticResource Loc}}" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.TimeZones}"
                                          SelectedItem="{x:Bind ViewModel.TimeZone, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [CVM_ProductKey], Source={StaticResource Loc}}" FontSize="12"/>
                            <TextBox Text="{x:Bind ViewModel.ProductKey, Mode=TwoWay}"
                                     PlaceholderText="XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"
                                     FontFamily="Consolas"/>
                        </StackPanel>
                        <Expander Header="{Binding [CVM_XmlPreview], Source={StaticResource Loc}}" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="8">
                                <ScrollViewer Height="180">
                                    <TextBlock Text="{x:Bind ViewModel.AnswerFilePreview, Mode=OneWay}"
                                               FontFamily="Consolas" FontSize="11"
                                               IsTextSelectionEnabled="True" TextWrapping="NoWrap"/>
                                </ScrollViewer>
                                <Button Content="{Binding [CVM_UpdatePreview], Source={StaticResource Loc}}"
                                        Command="{x:Bind ViewModel.UpdateAnswerPreviewCommand}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Create button -->
            <Button Command="{x:Bind ViewModel.CreateVmCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Padding="0,14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE945;" FontSize="16"/>
                    <TextBlock Text="{Binding [CVM_BtnCreate], Source={StaticResource Loc}}" FontSize="14"/>
                </StackPanel>
            </Button>

            <!-- Status -->
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                       FontSize="13" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</Page>
