<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.BaseVhdxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HVLab.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="28,20,28,20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Images de base VHDX" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           FontSize="13" Foreground="{ThemeResource SystemBaseMediumColor}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Actualiser"/>
                </StackPanel>
            </Button>
        </Grid>

        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Build progress InfoBar -->
        <InfoBar Grid.Row="2"
                 IsOpen="{x:Bind ViewModel.IsCreating, Mode=OneWay}"
                 Severity="Informational"
                 Title="Construction en cours"
                 Message="{x:Bind ViewModel.BuildStatus, Mode=OneWay}"
                 IsClosable="False"/>

        <!-- Existing images list -->
        <Grid Grid.Row="3" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Grid Grid.Row="0"
                  Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                  Padding="12,6" CornerRadius="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Nom"       FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="Chemin"    FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="Taille"    FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="Créé le"   FontWeight="SemiBold"/>
                <TextBlock Grid.Column="4" Text="Action"    FontWeight="SemiBold"/>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.BaseVhdxList, Mode=OneWay}"
                      SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"                    Value="12,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="MinHeight"                  Value="42"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BaseVhdx">
                        <Grid ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind StatusIcon}" FontSize="14"/>
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind Name}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{x:Bind Path}"
                                       FontFamily="Consolas" FontSize="11"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                       ToolTipService.ToolTip="{x:Bind Path}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind CreatedAtDisplay}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="4" Tag="{x:Bind}" Click="DeleteVhdx_Click"
                                    Width="32" Height="32" Padding="0"
                                    ToolTipService.ToolTip="Supprimer">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Create VHDX expander -->
            <Expander Grid.Row="2" Header="➕  Créer une nouvelle image de base"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <ScrollViewer MaxHeight="520">
                    <StackPanel Spacing="14" Padding="0,8,0,4">

                        <!-- VHDX settings -->
                        <TextBlock Text="Paramètres du disque" FontWeight="SemiBold" FontSize="14"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Nom du VHDX" FontSize="12"/>
                                <TextBox Text="{x:Bind ViewModel.VhdxName, Mode=TwoWay}"
                                         PlaceholderText="Win11-Base"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Taille (Go)" FontSize="12"/>
                                <NumberBox Value="{x:Bind ViewModel.SizeGB, Mode=TwoWay}"
                                           Minimum="20" Maximum="500" SpinButtonPlacementMode="Inline"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Génération" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.Generations}"
                                          SelectedItem="{x:Bind ViewModel.Generation, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="4">
                                <TextBlock Text="Index image" FontSize="12"/>
                                <NumberBox Value="{x:Bind ViewModel.ImageIndex, Mode=TwoWay}"
                                           Minimum="1" Maximum="20" SpinButtonPlacementMode="Inline"/>
                            </StackPanel>
                        </Grid>

                        <!-- Dossier de sortie -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Dossier de destination" FontSize="12"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.BaseFolder, Mode=TwoWay}"
                                         PlaceholderText="C:\HV-LAB\BaseImages"/>
                                <Button Grid.Column="1" Content="Parcourir…" Click="BrowseBaseFolder_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- WIM source -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Fichier source Windows (WIM/ESD)" FontSize="12"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.WimPath, Mode=TwoWay}"
                                         PlaceholderText="D:\sources\install.wim" FontFamily="Consolas" FontSize="12"/>
                                <Button Grid.Column="1" Content="Parcourir…" Click="BrowseWim_Click"/>
                            </Grid>
                            <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                                     Message="Windows 11 utilise install.esd. Exportez-le en .wim avec DISM si nécessaire."/>
                        </StackPanel>

                        <!-- Answer file section -->
                        <ToggleSwitch Header="Fichier de réponse (unattend.xml)"
                                      IsOn="{x:Bind ViewModel.UseAnswerFile, Mode=TwoWay}"/>

                        <StackPanel Spacing="12"
                                    Visibility="{x:Bind ViewModel.UseAnswerFile, Mode=OneWay,
                                                  Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Configuration unattend.xml" FontWeight="SemiBold" FontSize="14"/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Nom de l'ordinateur" FontSize="12"/>
                                    <TextBox Text="{x:Bind ViewModel.ComputerName, Mode=TwoWay}"
                                             PlaceholderText="LAB-VM"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Mot de passe Administrateur" FontSize="12"/>
                                    <PasswordBox Password="{x:Bind ViewModel.AdminPassword, Mode=TwoWay}"
                                                 PlaceholderText="P@ssw0rd!"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Langue / Locale" FontSize="12"/>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.Languages}"
                                              SelectedItem="{x:Bind ViewModel.UiLanguage, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Fuseau horaire" FontSize="12"/>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.TimeZones}"
                                              SelectedItem="{x:Bind ViewModel.TimeZone, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Clé produit (optionnel)" FontSize="12"/>
                                <TextBox Text="{x:Bind ViewModel.ProductKey, Mode=TwoWay}"
                                         PlaceholderText="XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"
                                         FontFamily="Consolas"/>
                            </StackPanel>
                            <Expander Header="Aperçu unattend.xml" HorizontalAlignment="Stretch">
                                <ScrollViewer Height="200">
                                    <TextBlock Text="{x:Bind ViewModel.AnswerFilePreview, Mode=OneWay}"
                                               FontFamily="Consolas" FontSize="11"
                                               IsTextSelectionEnabled="True" TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </Expander>
                            <Button Content="Mettre à jour l'aperçu"
                                    Command="{x:Bind ViewModel.UpdateAnswerPreviewCommand}"/>
                        </StackPanel>

                        <!-- Create button -->
                        <Button Content="🔨  Créer l'image de base"
                                Command="{x:Bind ViewModel.CreateBaseVhdxCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsCreating, Mode=OneWay,
                                             Converter={StaticResource BoolInverseConverter}}"/>

                    </StackPanel>
                </ScrollViewer>
            </Expander>

        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="4"
                   Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                   FontSize="12" Foreground="{ThemeResource SystemBaseMediumColor}"/>
    </Grid>
</Page>
