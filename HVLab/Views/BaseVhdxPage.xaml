<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HVLab.Views.BaseVhdxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HVLab.Models"
    Background="Transparent">

    <ScrollViewer>
        <Grid Padding="36,24,36,20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding [BV_Title], Source={StaticResource Loc}}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="{Binding [Btn_Refresh], Source={StaticResource Loc}}"/>
                </StackPanel>
            </Button>
        </Grid>

        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Build progress InfoBar -->
        <InfoBar Grid.Row="2"
                 IsOpen="{x:Bind ViewModel.IsCreating, Mode=OneWay}"
                 Severity="Informational"
                 Title="Construction en cours / Building"
                 Message="{x:Bind ViewModel.BuildStatus, Mode=OneWay}"
                 IsClosable="False"/>

        <!-- Main content -->
        <Grid Grid.Row="3" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Grid Grid.Row="0"
                  Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                  Padding="12,6" CornerRadius="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding [BV_ColOS], Source={StaticResource Loc}}"      FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding [BV_ColVersion], Source={StaticResource Loc}}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="{Binding [BV_ColEdition], Source={StaticResource Loc}}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="{Binding [BV_ColSize], Source={StaticResource Loc}}"    FontWeight="SemiBold"/>
                <TextBlock Grid.Column="4" Text="{Binding [BV_ColDate], Source={StaticResource Loc}}"    FontWeight="SemiBold"/>
                <TextBlock Grid.Column="5" Text="{Binding [BV_ColAction], Source={StaticResource Loc}}"  FontWeight="SemiBold"/>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.BaseVhdxList, Mode=OneWay}"
                      SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"                    Value="12,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="MinHeight"                  Value="44"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BaseVhdx">
                        <Grid ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <!-- OS label + icon -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind StatusIcon}" FontSize="16"/>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind OsLabel}"
                                               FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind Name}"/>
                                    <TextBlock Text="{x:Bind FilePath}"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind FilePath}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{x:Bind OsVersion}"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"
                                       ToolTipService.ToolTip="{x:Bind OsVersion}"/>

                            <TextBlock Grid.Column="2" Text="{x:Bind OsIdentifier}"
                                       FontSize="12" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind OsIdentifier}"/>

                            <TextBlock Grid.Column="3" Text="{x:Bind SizeDisplay}"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="4" Text="{x:Bind CreatedAtDisplay}"
                                       VerticalAlignment="Center" FontSize="12"/>

                            <Button Grid.Column="5" Tag="{x:Bind}" Click="DeleteVhdx_Click"
                                    Width="32" Height="32" Padding="0"
                                    ToolTipService.ToolTip="Delete / Supprimer">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Create VHDX expander -->
            <Expander Grid.Row="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="{Binding [BV_CreateTitle], Source={StaticResource Loc}}" FontSize="14"/>
                    </StackPanel>
                </Expander.Header>
                <ScrollViewer>
                    <StackPanel Spacing="16" Padding="0,10,0,6">

                        <!-- ══ Étape 1 : Fichier source WIM/ESD ══════════════════════════════ -->
                        <TextBlock Text="{Binding [BV_StepWim], Source={StaticResource Loc}}"
                                   FontWeight="SemiBold" FontSize="14"/>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.WimPath, Mode=TwoWay}"
                                     PlaceholderText="D:\sources\install.wim  ou  install.esd"
                                     FontFamily="Consolas" FontSize="12"
                                     IsReadOnly="False"/>
                            <Button Grid.Column="1" Content="{Binding [BV_BrowseWim], Source={StaticResource Loc}}" Click="BrowseWim_Click"
                                    VerticalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="{Binding [BV_Analyze], Source={StaticResource Loc}}"
                                    Command="{x:Bind ViewModel.AnalyzeWimCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    VerticalAlignment="Stretch">
                                <Button.IsEnabled>
                                    <x:Boolean>True</x:Boolean>
                                </Button.IsEnabled>
                            </Button>
                        </Grid>

                        <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                                 Message="Windows 11 uses install.esd — export to .wim with DISM. / Windows 11 utilise install.esd — exportez en .wim avec DISM."/>

                        <!-- Résultats d'analyse WIM -->
                        <ProgressBar IsIndeterminate="True"
                                     Visibility="{x:Bind ViewModel.IsAnalyzingWim, Mode=OneWay,
                                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Carte résultats -->
                        <Border Visibility="{x:Bind ViewModel.WimAnalyzed, Mode=OneWay,
                                              Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="14"
                                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <TextBlock Text="WIM images / Images WIM"
                                               FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>

                                <!-- Liste de toutes les images du WIM -->
                                <ItemsControl ItemsSource="{x:Bind ViewModel.WimImages, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:WimImageInfo">
                                            <Grid ColumnSpacing="12" Padding="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="130"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="4" Width="28" Height="22">
                                                    <TextBlock Text="{x:Bind ImageIndex}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{x:Bind ImageName}"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTipService.ToolTip="{x:Bind Display}"/>
                                                <TextBlock Grid.Column="2" Text="{x:Bind Version}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Statut + index auto-sélectionné -->
                        <InfoBar IsOpen="{x:Bind ViewModel.WimAnalyzed, Mode=OneWay}"
                                 Severity="Success" IsClosable="False"
                                 Message="{x:Bind ViewModel.WimAnalysisStatus, Mode=OneWay}"/>

                        <!-- ══ Étape 2 : Identité de l'image ════════════════════════════════ -->
                        <TextBlock Text="{Binding [BV_StepOS], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,8,0,0"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding [BV_OsFamily], Source={StaticResource Loc}}" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.OsFamilies}"
                                          SelectedItem="{x:Bind ViewModel.SelectedOsFamily, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding [BV_Edition], Source={StaticResource Loc}}" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableEditions}"
                                          SelectedItem="{x:Bind ViewModel.SelectedEdition, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Bottom"
                                        Visibility="{x:Bind ViewModel.ShowDesktopExperience, Mode=OneWay,
                                                      Converter={StaticResource BoolToVisibilityConverter}}">
                                <CheckBox Content="{Binding [BV_DesktopExp], Source={StaticResource Loc}}"
                                          IsChecked="{x:Bind ViewModel.DesktopExperience, Mode=TwoWay}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Version OS : auto-remplie par l'analyse WIM, modifiable manuellement -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding [BV_OsVersion], Source={StaticResource Loc}}" FontSize="12"/>
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="5,1"
                                            Visibility="{x:Bind ViewModel.WimAnalyzed, Mode=OneWay,
                                                          Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Auto" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBox Text="{x:Bind ViewModel.OsVersion, Mode=TwoWay}"
                                         PlaceholderText="10.0.26100.4652  (détectée automatiquement)"
                                         FontFamily="Consolas"/>
                            </StackPanel>
                            <!-- Index WIM : auto-sélectionné par l'analyse -->
                            <StackPanel Grid.Column="1" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding [BV_ImageIndex], Source={StaticResource Loc}}" FontSize="12"/>
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="5,1"
                                            Visibility="{x:Bind ViewModel.WimAnalyzed, Mode=OneWay,
                                                          Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Auto" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <NumberBox Value="{x:Bind ViewModel.ImageIndex, Mode=TwoWay}"
                                           Minimum="1" Maximum="20"
                                           SpinButtonPlacementMode="Inline"
                                           Width="110"/>
                            </StackPanel>
                        </Grid>

                        <!-- Filename preview -->
                        <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                CornerRadius="6" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding [BV_Preview], Source={StaticResource Loc}}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.PreviewFileName, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="Wrap"/>
                                <TextBlock FontSize="11" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="→ "/>
                                    <Run Text="{x:Bind ViewModel.BaseFolder, Mode=OneWay}"/>
                                    <Run Text="\"/>
                                    <Run Text="{x:Bind ViewModel.PreviewFileName, Mode=OneWay}"/>
                                    <Run Text=".vhdx"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- ══ Étape 3 : Paramètres du disque ═══════════════════════════════ -->
                        <TextBlock Text="{Binding [BV_StepDisk], Source={StaticResource Loc}}" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,8,0,0"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding [BV_SizeGB], Source={StaticResource Loc}}" FontSize="12"/>
                                <NumberBox Value="{x:Bind ViewModel.SizeGB, Mode=TwoWay}"
                                           Minimum="20" Maximum="500" SpinButtonPlacementMode="Inline"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding [BV_Generation], Source={StaticResource Loc}}" FontSize="12"/>
                                <ComboBox ItemsSource="{x:Bind ViewModel.Generations}"
                                          SelectedItem="{x:Bind ViewModel.Generation, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Dossier de sortie -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [BV_DestFolder], Source={StaticResource Loc}}" FontSize="12"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.BaseFolder, Mode=TwoWay}"
                                         PlaceholderText="C:\HV-LAB\BaseImages"/>
                                <Button Grid.Column="1" Content="{Binding [Btn_Browse], Source={StaticResource Loc}}" Click="BrowseBaseFolder_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Note: pas de fichier de réponse sur l'image de base -->
                        <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                                 Title="{Binding [BV_SysprepInfo], Source={StaticResource Loc}}"
                                 Message="{Binding [BV_SysprepMsg], Source={StaticResource Loc}}"/>

                        <!-- ══ Créer ════════════════════════════════════════════════════════ -->
                        <Button Command="{x:Bind ViewModel.CreateBaseVhdxCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsCreating, Mode=OneWay,
                                             Converter={StaticResource BoolInverseConverter}}"
                                Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE90F;" FontSize="14"/>
                                <TextBlock Text="{Binding [BV_BtnCreate], Source={StaticResource Loc}}"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Expander>

        </Grid>
        </Grid>
    </ScrollViewer>
</Page>
