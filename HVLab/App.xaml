<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HVLab.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:HVLab.Converters"
    xmlns:services="using:HVLab.Services">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- CommunityToolkit SettingsControls (SettingsCard, SettingsExpander) -->
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.SettingsControls/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter"/>
            <converters:StateToColorConverter x:Key="StateToColorConverter"/>
            <services:LocalizationHelper x:Key="Loc"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
